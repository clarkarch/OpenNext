# OpenNext Android

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
app/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
*.ipr
*.iws

# Keystore files
# (Do not check these into version control)
*.jks
*.keystore

# Google Services (Uncomment if using Firebase and want to keep config private)
# google-services.json

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# NDK
obj/
bin/
libs/

# Gradle wrapper (do not ignore - we want this in VCS)
# gradle/wrapper/gradle-wrapper.jar

# OS-specific
.DS_Store
Thumbs.db

# Environment
.env
.env.*
