{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@shared/*": [
        "./src/shared/*"
      ]
    },
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "electron-vite/node"
    ],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "electron.vite.config.ts",
    "webos.vite.config.ts",
    "webos/service-src",
    "src/main",
    "src/preload",
    "src/shared"
  ]
}
